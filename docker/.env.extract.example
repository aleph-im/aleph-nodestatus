# === Extraction service env (nodestatus-extract) ===
#
# This key signs the on-chain process() transactions that sweep USDC / ETH /
# ALEPH balances out of the AlephPaymentProcessor and into the distribution
# wallet. The address derived from this key MUST be the processor admin
# (settings.payment_processor_admin_address) and MUST hold enough ETH to
# cover gas for ~one process() tx per configured token at ~50 gwei.
#
# Two ways to provide the signing key:
#
#   1. payment_processor_admin_pkey=<admin_private_key>   (preferred)
#   2. leave it unset and provide ethereum_pkey below as a fallback;
#      the orchestrator will log a WARNING on each run.
payment_processor_admin_pkey=<processor_admin_private_key>

# Optional fallback. Only consulted if payment_processor_admin_pkey is empty.
# ethereum_pkey=<fallback_private_key>

ethereum_api_server=<your eth rpc>

# === Swap parameters — uncomment to override defaults ===
#
# Slippage tolerance applied to the quoter's expected_out when computing
# the on-chain minOut floor. 100 bps = 1%. Raise for thin liquidity; lower
# for stricter execution. CLI: --slippage-bps N.
# process_slippage_bps=100
#
# Per-token floor on the swap amount (human units, decimals-aware). If the
# extractable amount drops below this for a given token, the cron skips it
# this cycle so gas doesn't dominate the value moved. Override the whole
# map here, or override per-token at the CLI with --min-amount SYM=N.
# Format: JSON dict, string values (Decimal-parsed at consumption).
# extract_default_min_amounts={"USDC":"100","ETH":"0.025","ALEPH":"500"}
#
# Auto-sizing: max price impact (bps) tolerated when bisecting the swap
# amount. The extractor probes the quoter at a small reference size, then
# at the candidate, derives implied impact, and bisects down until under
# this ceiling. 100 bps = 1%. 0 disables auto-sizing (full or capped
# balance is swapped). CLI: --max-price-impact-bps N.
# extract_max_price_impact_bps=100

# === Anti-MEV (Phase 1) — uncomment to override defaults ===
#
# Random delay (anti-tracking): uniform 0..N seconds before the actual
# extract run. Set to 0 to disable jitter (e.g., for staging/testing).
# extract_random_delay_max_seconds=3540
#
# Pool-spot vs Chainlink deviation guard. If any hop exceeds the
# threshold, that token is skipped and retried next hour.
# extract_max_deviation_bps=200
#
# Reject Chainlink readings older than this many seconds (default 1h —
# matches the mainnet ETH/USD heartbeat).
# chainlink_max_age_seconds=3600

# === Fork-mode audit (dry-run against `anvil --fork-url …`) ===
#
# Optional URL of a local mainnet fork. When set, `extract-credits
# --dry-run` upgrades to full sign+broadcast against the fork and
# reconciles each receipt's TokenPaymentsProcessed event against the
# quoter's expected_out. CLI: --fork-rpc URL.
# extract_fork_rpc=
#
# Max acceptable delta between realized alephReceived and quoter
# expected_out, in bps. Only consulted in fork mode. CLI: --reconcile-bps.
# extract_max_reconcile_delta_bps=200

# All other settings inherit pydantic defaults. Add overrides below as needed.
